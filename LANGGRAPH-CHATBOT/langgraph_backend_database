from langgraph.graph import StateGraph, START, END
from typing import TypedDict, Annotated
from langchain_core.messages import BaseMessage, HumanMessage
# 1. Swap the import
from langchain_google_genai import ChatGoogleGenerativeAI 
from langgraph.checkpoint.memory import InMemorySaver
from langgraph.graph.message import add_messages
from dotenv import load_dotenv
from langgraph.checkpoint.postgres import PostgresSaver
import os

load_dotenv()
DB_URI = os.getenv("DB_URI")

# 2. Initialize Gemini 
# Make sure GOOGLE_API_KEY is in your .env
# Change this line:
# OR try the full path:
# Initialize Gemini with explicit API version and correct model string
llm = ChatGoogleGenerativeAI(
    model="gemini-2.5-flash"
    # Forces the REST transport which is more stable for v1
    # Remove api_version if it causes an 'Unexpected argument' error
)

class ChatState(TypedDict):
    messages: Annotated[list[BaseMessage], add_messages]

def chat_node(state: ChatState) -> ChatState:
    messages = state['messages']
    response = llm.invoke(messages)
    return {'messages': [response]}

def build_graph(checkpointer):
    workflow = StateGraph(ChatState)
    workflow.add_node("chat_node", chat_node)
    workflow.add_edge(START, "chat_node")
    workflow.add_edge("chat_node", END)
    # Use the compile method on the graph
    return workflow.compile(checkpointer=checkpointer)

# 1. Create the context manager (the "wrapper")
checkpointer_manager = PostgresSaver.from_conn_string(DB_URI)

# 2. "Enter" the manager manually to get the actual checkpointer object
# This opens the connection to your Postgres DB
checkpointer = checkpointer_manager.__enter__()

# 3. Now you can call .setup() on the actual object
checkpointer.setup()

chatbot = build_graph(checkpointer)
def retrieve_all_threads():
    all_threads=set()
    for checkpoint in checkpointer.list(None):
        all_threads.add(checkpoint.config['configurable']['thread_id'])
    return list(all_threads)
